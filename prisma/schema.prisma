generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  INSTRUCTOR
  RECRUITER
  ADMIN
}

enum LabType {
  CTF
  BLUE_TEAM
  RED_TEAM
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  INSANE
}

enum AttemptStatus {
  IN_PROGRESS
  SOLVED
  ABANDONED
}

model User {
  id          String   @id @default(cuid())
  clerkId     String?  @unique
  email       String   @unique
  password    String?
  displayName  String?
  role         Role     @default(STUDENT)
  university   String?
  linkedIn     String?
  github       String?
  skillScore   Int      @default(0)
  xp           Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  // Extended profile fields
  bio          String?
  skills       String[]
  cvUrl        String?
  company      String?
  jobTitle     String?
  website      String?
  profileExtra Json?
  // Stripe billing
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  subscriptionStatus   String?  // active | trialing | canceled | past_due
  subscriptionPlan     String?  // classroom | enterprise
  trialEndsAt          DateTime?

  attempts               Attempt[]
  labResponses           LabResponse[]
  aiEvaluations          AIEvaluation[]
  simSessions            SimulationSession[]
  instructorClassrooms   Classroom[]           @relation("InstructorClassrooms")
  enrollments            ClassroomEnrollment[]
  pathProgress           UserPathProgress[]
  usedHints              UsedHint[]
  jobPostings            JobPosting[]          @relation("RecruiterPostings")
  recruiterBookmarks     CandidateBookmark[]   @relation("RecruiterBookmarks")
  candidateBookmarks     CandidateBookmark[]   @relation("CandidateBookmarks")
  ledTeams               TeamSession[]         @relation("TeamLead")
  teamMemberships        TeamMember[]
  certification            IRCertification?
  competitionEntries       CompetitionEntry[]
  institutionMemberships   InstitutionMember[]
  feedReactions            FeedReaction[]

  @@index([skillScore])
}

model Lab {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  description String
  type        LabType
  difficulty  Difficulty
  category    String
  points      Int        @default(100)
  published   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  flags                Flag[]
  attempts             Attempt[]
  labResponses         LabResponse[]
  classroomAssignments ClassroomLabAssignment[]
  pathLabs             PathLab[]
  hints                LabHint[]

  @@index([type, difficulty])
}

model Flag {
  id            String  @id @default(cuid())
  labId         String
  value         String
  points        Int     @default(100)
  caseSensitive Boolean @default(true)

  lab Lab @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@index([labId])
}

model Attempt {
  id           String        @id @default(cuid())
  userId       String
  labId        String
  status       AttemptStatus @default(IN_PROGRESS)
  score        Int           @default(0)
  startedAt    DateTime      @default(now())
  solvedAt     DateTime?
  timeTakenSec Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab  Lab  @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@unique([userId, labId])
  @@index([userId])
  @@index([labId])
}

model LabResponse {
  id        String   @id @default(cuid())
  userId    String
  labId     String
  stage     String
  response  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab           Lab            @relation(fields: [labId], references: [id], onDelete: Cascade)
  aiEvaluation  AIEvaluation?

  @@unique([userId, labId, stage])
  @@index([userId])
  @@index([labId])
}

model AIEvaluation {
  id               String   @id @default(cuid())
  userId           String
  labId            String?
  labResponseId    String?  @unique
  accuracyScore    Int
  clarityScore     Int
  completenessScore Int
  recommendation   String
  feedback         String   @db.Text
  createdAt        DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  labResponse LabResponse? @relation(fields: [labResponseId], references: [id])

  @@index([userId])
}

// ── Simulation Engine ─────────────────────────────────────────────────────────

enum SimulationStatus {
  ACTIVE
  CONTAINED
  BREACHED
  ABANDONED
}

model ScenarioTemplate {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  description String
  industry    String
  difficulty  Difficulty
  published   Boolean    @default(true)
  createdAt   DateTime   @default(now())

  sessions SimulationSession[]
}

model SimulationSession {
  id              String           @id @default(cuid())
  userId          String
  templateId      String
  companyData     Json
  status          SimulationStatus @default(ACTIVE)
  currentStage    String           @default("NORMAL")
  score           Int              @default(0)
  startedAt       DateTime         @default(now())
  endedAt         DateTime?
  adversaryState  Json?
  adversaryMemory Json?
  scenarioId      String?
  personaId       String?

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  template    ScenarioTemplate  @relation(fields: [templateId], references: [id])
  events      SimulationEvent[]
  teamSession TeamSession?

  @@index([userId])
  @@index([status])
}

model SimulationEvent {
  id        String   @id @default(cuid())
  sessionId String
  type      String
  actor     String
  payload   Json
  narrative String?  @db.Text
  createdAt DateTime @default(now())

  session SimulationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

// ── Classroom ─────────────────────────────────────────────────────────────────

model Classroom {
  id           String   @id @default(cuid())
  name         String
  joinCode     String   @unique
  instructorId String
  webhookUrl   String?
  createdAt    DateTime @default(now())

  instructor      User                     @relation("InstructorClassrooms", fields: [instructorId], references: [id], onDelete: Cascade)
  enrollments     ClassroomEnrollment[]
  assignments     ClassroomLabAssignment[]
  announcements   ClassroomAnnouncement[]
  simAssignments  ClassroomSimAssignment[]

  @@index([instructorId])
}

model ClassroomAnnouncement {
  id          String   @id @default(cuid())
  classroomId String
  content     String
  createdAt   DateTime @default(now())

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@index([classroomId])
}

model ClassroomSimAssignment {
  id          String    @id @default(cuid())
  classroomId String
  scenarioId  String
  title       String
  assignedAt  DateTime  @default(now())
  dueDate     DateTime?

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@unique([classroomId, scenarioId])
  @@index([classroomId])
}

model ClassroomEnrollment {
  id          String   @id @default(cuid())
  classroomId String
  userId      String
  enrolledAt  DateTime @default(now())

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classroomId, userId])
  @@index([userId])
}

model ClassroomLabAssignment {
  id          String    @id @default(cuid())
  classroomId String
  labId       String
  assignedAt  DateTime  @default(now())
  dueDate     DateTime?

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  lab       Lab       @relation(fields: [labId], references: [id])

  @@unique([classroomId, labId])
}

// ── Learning Paths ────────────────────────────────────────────────────────────

model LearningPath {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())

  labs     PathLab[]
  progress UserPathProgress[]
}

model PathLab {
  id     String @id @default(cuid())
  pathId String
  labId  String
  order  Int

  path LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  lab  Lab          @relation(fields: [labId], references: [id])

  @@unique([pathId, labId])
  @@unique([pathId, order])
}

model UserPathProgress {
  id          String    @id @default(cuid())
  userId      String
  pathId      String
  completedAt DateTime?
  startedAt   DateTime  @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  path LearningPath @relation(fields: [pathId], references: [id])

  @@unique([userId, pathId])
  @@index([userId])
}

// ── Hint System ───────────────────────────────────────────────────────────────

model LabHint {
  id        String @id @default(cuid())
  labId     String
  stage     String
  level     Int
  text      String @db.Text
  pointCost Int    @default(10)

  lab  Lab        @relation(fields: [labId], references: [id], onDelete: Cascade)
  used UsedHint[]

  @@unique([labId, stage, level])
  @@index([labId, stage])
}

model UsedHint {
  id     String   @id @default(cuid())
  userId String
  hintId String
  usedAt DateTime @default(now())

  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  hint LabHint @relation(fields: [hintId], references: [id])

  @@unique([userId, hintId])
  @@index([userId])
}

// ── Recruiter Marketplace ─────────────────────────────────────────────────────

model JobPosting {
  id           String   @id @default(cuid())
  recruiterId  String
  title        String
  company      String
  description  String   @db.Text
  requirements Json
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  recruiter User                @relation("RecruiterPostings", fields: [recruiterId], references: [id], onDelete: Cascade)
  bookmarks CandidateBookmark[]

  @@index([recruiterId])
  @@index([active])
}

model CandidateBookmark {
  id          String   @id @default(cuid())
  recruiterId String
  candidateId String
  jobId       String?
  note        String?
  createdAt   DateTime @default(now())

  recruiter User        @relation("RecruiterBookmarks", fields: [recruiterId], references: [id], onDelete: Cascade)
  candidate User        @relation("CandidateBookmarks", fields: [candidateId], references: [id], onDelete: Cascade)
  job       JobPosting? @relation(fields: [jobId], references: [id])

  @@unique([recruiterId, candidateId])
  @@index([recruiterId])
}

// ── Team Simulations ──────────────────────────────────────────────────────────

enum TeamStatus {
  LOBBY
  ACTIVE
  COMPLETE
}

enum TeamRole {
  IR_LEAD
  FORENSICS
  LEGAL
  COMMS
}

model TeamSession {
  id           String     @id @default(cuid())
  code         String     @unique
  leadId       String
  sessionId    String?    @unique
  templateSlug String
  status       TeamStatus @default(LOBBY)
  createdAt    DateTime   @default(now())

  lead    User               @relation("TeamLead", fields: [leadId], references: [id], onDelete: Cascade)
  session SimulationSession? @relation(fields: [sessionId], references: [id])
  members TeamMember[]

  @@index([leadId])
  @@index([status])
}

model TeamMember {
  id            String    @id @default(cuid())
  teamSessionId String
  userId        String
  role          TeamRole?
  joinedAt      DateTime  @default(now())

  teamSession TeamSession @relation(fields: [teamSessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamSessionId, userId])
  @@index([teamSessionId])
}

// ── Credentialing ─────────────────────────────────────────────────────────────

model IRCertification {
  id         String   @id @default(cuid())
  userId     String   @unique
  certId     String   @unique
  unlockedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([certId])
}

// ── Institutional Licensing ───────────────────────────────────────────────────

enum InstitutionPlan {
  TRIAL
  BASIC
  PRO
  ENTERPRISE
}

model Institution {
  id               String          @id @default(cuid())
  name             String
  contactEmail     String
  plan             InstitutionPlan @default(TRIAL)
  seats            Int             @default(30)
  active           Boolean         @default(true)
  expiresAt        DateTime?
  joinCode         String          @unique
  stripeCustomerId String?
  notes            String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  members InstitutionMember[]
}

model InstitutionMember {
  id            String      @id @default(cuid())
  institutionId String
  userId        String
  isAdmin       Boolean     @default(false)
  joinedAt      DateTime    @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([institutionId, userId])
  @@index([institutionId])
  @@index([userId])
}

// ── Competitions ──────────────────────────────────────────────────────────────

model Competition {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  startDate   DateTime
  endDate     DateTime
  published   Boolean  @default(false)
  labSlugs    Json
  createdAt   DateTime @default(now())

  entries CompetitionEntry[]
}

model CompetitionEntry {
  id            String    @id @default(cuid())
  competitionId String
  userId        String
  score         Int       @default(0)
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([competitionId, userId])
  @@index([competitionId])
  @@index([userId])
}

// ── Feed Reactions ────────────────────────────────────────────────────────────

model FeedReaction {
  id        String   @id @default(cuid())
  userId    String
  entryId   String
  entryType String
  reaction  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entryId, entryType, reaction])
  @@index([entryId, entryType])
  @@index([userId])
}

// ── Rate Limiting ─────────────────────────────────────────────────────────────

model RateLimitEvent {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

// ── Stripe Webhook Idempotency ────────────────────────────────────────────────

model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  processedAt   DateTime @default(now())
}

// ── Product Analytics ─────────────────────────────────────────────────────────

model AnalyticsEvent {
  id         String   @id @default(cuid())
  event      String
  userId     String?
  properties Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([event, createdAt])
  @@index([userId, createdAt])
}
