generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  INSTRUCTOR
  RECRUITER
  ADMIN
}

enum LabType {
  CTF
  BLUE_TEAM
  RED_TEAM
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  INSANE
}

enum AttemptStatus {
  IN_PROGRESS
  SOLVED
  ABANDONED
}

model User {
  id          String   @id @default(cuid())
  clerkId     String?  @unique
  // Opaque foreign-system user id (e.g. a future Nexus-provisioned account).
  // Not used yet — reserved so account linking doesn't require a schema change later.
  externalId  String?  @unique
  email       String   @unique
  password    String?
  displayName  String?
  role         Role     @default(STUDENT)
  university   String?
  linkedIn     String?
  github       String?
  skillScore   Int      @default(0)
  xp           Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  // Extended profile fields
  bio          String?
  avatarUrl    String?
  skills       String[]
  cvUrl        String?
  company      String?
  jobTitle     String?
  website      String?
  profileExtra Json?
  // Stripe billing
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  subscriptionStatus   String?  // active | trialing | canceled | past_due
  subscriptionPlan     String?  // classroom | enterprise
  trialEndsAt          DateTime?

  attempts               Attempt[]
  writeups               Writeup[]
  labResponses           LabResponse[]
  aiEvaluations          AIEvaluation[]
  simSessions            SimulationSession[]
  instructorClassrooms   Classroom[]           @relation("InstructorClassrooms")
  enrollments            ClassroomEnrollment[]
  pathProgress           UserPathProgress[]
  usedHints              UsedHint[]
  jobPostings            JobPosting[]          @relation("RecruiterPostings")
  recruiterBookmarks     CandidateBookmark[]   @relation("RecruiterBookmarks")
  candidateBookmarks     CandidateBookmark[]   @relation("CandidateBookmarks")
  ledTeams               TeamSession[]         @relation("TeamLead")
  teamMemberships        TeamMember[]
  customScenarios        CustomScenario[]      @relation("CreatedCustomScenarios")
  notifications          Notification[]
  certification            IRCertification?
  competitionEntries       CompetitionEntry[]
  organizationMemberships  OrganizationMember[]
  feedReactions            FeedReaction[]
  feedComments             FeedComment[]
  quizAttempts             QuizAttempt[]
  assessmentSubmissions    AssessmentSubmission[]
  mentorReviews            MentorReview[]         @relation("MentorReviews")
  portfolioItems           PortfolioItem[]
  moduleProgress           UserModuleProgress[]
  cohortMemberships        CohortMember[]

  @@index([skillScore])
}

model Lab {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  description String
  type        LabType
  difficulty  Difficulty
  category    String
  points      Int        @default(100)
  published   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  flags                Flag[]
  attempts             Attempt[]
  labResponses         LabResponse[]
  classroomAssignments ClassroomLabAssignment[]
  pathLabs             PathLab[]
  hints                LabHint[]
  writeups             Writeup[]

  @@index([type, difficulty])
}

model Flag {
  id            String  @id @default(cuid())
  labId         String
  value         String
  points        Int     @default(100)
  caseSensitive Boolean @default(true)

  lab Lab @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@index([labId])
}

model Attempt {
  id           String        @id @default(cuid())
  userId       String
  labId        String
  status       AttemptStatus @default(IN_PROGRESS)
  score        Int           @default(0)
  startedAt    DateTime      @default(now())
  solvedAt     DateTime?
  timeTakenSec Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab  Lab  @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@unique([userId, labId])
  @@index([userId])
  @@index([labId])
}

model LabResponse {
  id        String   @id @default(cuid())
  userId    String
  labId     String
  stage     String
  response  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab           Lab            @relation(fields: [labId], references: [id], onDelete: Cascade)
  aiEvaluation  AIEvaluation?

  @@unique([userId, labId, stage])
  @@index([userId])
  @@index([labId])
}

model AIEvaluation {
  id               String   @id @default(cuid())
  userId           String
  labId            String?
  labResponseId    String?  @unique
  accuracyScore    Int
  clarityScore     Int
  completenessScore Int
  recommendation   String
  feedback         String   @db.Text
  createdAt        DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  labResponse LabResponse? @relation(fields: [labResponseId], references: [id])

  @@index([userId])
}

// ── Simulation Engine ─────────────────────────────────────────────────────────

enum SimulationStatus {
  ACTIVE
  CONTAINED
  BREACHED
  ABANDONED
}

model CustomScenario {
  id                 String     @id @default(cuid())
  title              String
  subtitle           String
  briefing           String     @db.Text
  difficulty         Difficulty
  estimatedMinutes   Int        @default(45)
  personaId          String
  archetypeId        String
  templateSlug       String
  learningObjectives String[]
  tags               String[]
  realWorldAnalogue  String?
  published          Boolean    @default(false)
  createdById        String
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  createdBy User @relation("CreatedCustomScenarios", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([published])
}

model ScenarioTemplate {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  description String
  industry    String
  difficulty  Difficulty
  published   Boolean    @default(true)
  createdAt   DateTime   @default(now())

  sessions SimulationSession[]
}

model SimulationSession {
  id              String           @id @default(cuid())
  userId          String
  templateId      String
  companyData     Json
  status          SimulationStatus @default(ACTIVE)
  currentStage    String           @default("NORMAL")
  score           Int              @default(0)
  startedAt       DateTime         @default(now())
  endedAt         DateTime?
  adversaryState  Json?
  adversaryMemory Json?
  scenarioId      String?
  personaId       String?

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  template    ScenarioTemplate  @relation(fields: [templateId], references: [id])
  events      SimulationEvent[]
  teamSession TeamSession?

  @@index([userId])
  @@index([status])
}

model SimulationEvent {
  id        String   @id @default(cuid())
  sessionId String
  type      String
  actor     String
  payload   Json
  narrative String?  @db.Text
  createdAt DateTime @default(now())

  session SimulationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

// ── Classroom ─────────────────────────────────────────────────────────────────

model Classroom {
  id           String   @id @default(cuid())
  name         String
  joinCode     String   @unique
  instructorId String
  webhookUrl   String?
  createdAt    DateTime @default(now())

  instructor      User                     @relation("InstructorClassrooms", fields: [instructorId], references: [id], onDelete: Cascade)
  enrollments     ClassroomEnrollment[]
  assignments     ClassroomLabAssignment[]
  announcements   ClassroomAnnouncement[]
  simAssignments  ClassroomSimAssignment[]

  @@index([instructorId])
}

model ClassroomAnnouncement {
  id          String   @id @default(cuid())
  classroomId String
  content     String
  createdAt   DateTime @default(now())

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@index([classroomId])
}

model ClassroomSimAssignment {
  id          String    @id @default(cuid())
  classroomId String
  scenarioId  String
  title       String
  assignedAt  DateTime  @default(now())
  dueDate     DateTime?

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@unique([classroomId, scenarioId])
  @@index([classroomId])
}

model ClassroomEnrollment {
  id          String   @id @default(cuid())
  classroomId String
  userId      String
  enrolledAt  DateTime @default(now())

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classroomId, userId])
  @@index([userId])
}

model ClassroomLabAssignment {
  id          String    @id @default(cuid())
  classroomId String
  labId       String
  assignedAt  DateTime  @default(now())
  dueDate     DateTime?

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  lab       Lab       @relation(fields: [labId], references: [id])

  @@unique([classroomId, labId])
}

// ── Learning Paths ────────────────────────────────────────────────────────────

model LearningPath {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())

  labs        PathLab[]
  modules     Module[]
  progress    UserPathProgress[]
  cohortPaths CohortPath[]
}

model PathLab {
  id     String @id @default(cuid())
  pathId String
  labId  String
  order  Int

  path LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  lab  Lab          @relation(fields: [labId], references: [id])

  @@unique([pathId, labId])
  @@unique([pathId, order])
}

model UserPathProgress {
  id          String    @id @default(cuid())
  userId      String
  pathId      String
  completedAt DateTime?
  startedAt   DateTime  @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  path LearningPath @relation(fields: [pathId], references: [id])

  @@unique([userId, pathId])
  @@index([userId])
}

// ── Hint System ───────────────────────────────────────────────────────────────

model LabHint {
  id        String @id @default(cuid())
  labId     String
  stage     String
  level     Int
  text      String @db.Text
  pointCost Int    @default(10)

  lab  Lab        @relation(fields: [labId], references: [id], onDelete: Cascade)
  used UsedHint[]

  @@unique([labId, stage, level])
  @@index([labId, stage])
}

model UsedHint {
  id     String   @id @default(cuid())
  userId String
  hintId String
  usedAt DateTime @default(now())

  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  hint LabHint @relation(fields: [hintId], references: [id])

  @@unique([userId, hintId])
  @@index([userId])
}

// ── Recruiter Marketplace ─────────────────────────────────────────────────────

model JobPosting {
  id           String   @id @default(cuid())
  recruiterId  String
  title        String
  company      String
  description  String   @db.Text
  requirements Json
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  recruiter User                @relation("RecruiterPostings", fields: [recruiterId], references: [id], onDelete: Cascade)
  bookmarks CandidateBookmark[]

  @@index([recruiterId])
  @@index([active])
}

model CandidateBookmark {
  id          String   @id @default(cuid())
  recruiterId String
  candidateId String
  jobId       String?
  note        String?
  createdAt   DateTime @default(now())

  recruiter User        @relation("RecruiterBookmarks", fields: [recruiterId], references: [id], onDelete: Cascade)
  candidate User        @relation("CandidateBookmarks", fields: [candidateId], references: [id], onDelete: Cascade)
  job       JobPosting? @relation(fields: [jobId], references: [id])

  @@unique([recruiterId, candidateId])
  @@index([recruiterId])
}

// ── Team Simulations ──────────────────────────────────────────────────────────

enum TeamStatus {
  LOBBY
  ACTIVE
  COMPLETE
}

enum TeamRole {
  IR_LEAD
  FORENSICS
  LEGAL
  COMMS
}

model TeamSession {
  id           String     @id @default(cuid())
  code         String     @unique
  leadId       String
  sessionId    String?    @unique
  templateSlug String
  status       TeamStatus @default(LOBBY)
  createdAt    DateTime   @default(now())

  lead    User               @relation("TeamLead", fields: [leadId], references: [id], onDelete: Cascade)
  session SimulationSession? @relation(fields: [sessionId], references: [id])
  members TeamMember[]

  @@index([leadId])
  @@index([status])
}

model TeamMember {
  id            String    @id @default(cuid())
  teamSessionId String
  userId        String
  role          TeamRole?
  joinedAt      DateTime  @default(now())

  teamSession TeamSession @relation(fields: [teamSessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamSessionId, userId])
  @@index([teamSessionId])
}

// ── Credentialing ─────────────────────────────────────────────────────────────

model IRCertification {
  id         String   @id @default(cuid())
  userId     String   @unique
  certId     String   @unique
  unlockedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([certId])
}

// ── Organization Licensing ──────────────────────────────────────────────────
// NOTE: Organization/OrganizationMember are mapped onto the pre-existing
// Institution/InstitutionMember tables via @@map/@map — this is a pure
// rename at the Prisma Client level, no underlying table/column changes,
// so it's safe to `db push` without any data migration.

enum InstitutionPlan {
  TRIAL
  BASIC
  PRO
  ENTERPRISE
}

model Organization {
  id               String          @id @default(cuid())
  name             String
  contactEmail     String
  plan             InstitutionPlan @default(TRIAL)
  seats            Int             @default(30)
  active           Boolean         @default(true)
  expiresAt        DateTime?
  joinCode         String          @unique
  // Email domain (e.g. "cybersage.uk") — new signups with a matching email
  // domain are auto-joined to this org. Optional: orgs can also be joined
  // purely via joinCode.
  domain           String?         @unique
  stripeCustomerId String?
  notes            String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  members OrganizationMember[]
  cohorts Cohort[]

  @@map("Institution")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String   @map("institutionId")
  userId         String
  // Org Lead: can view aggregate team progress + export data for the org.
  // Stacks on top of the member's normal STUDENT/INSTRUCTOR/RECRUITER access —
  // it does not replace it.
  isLead         Boolean  @default(false) @map("isAdmin")
  joinedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("InstitutionMember")
}

// ── Competitions ──────────────────────────────────────────────────────────────

model Competition {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  startDate   DateTime
  endDate     DateTime
  published   Boolean  @default(false)
  labSlugs    Json
  createdAt   DateTime @default(now())

  entries CompetitionEntry[]
}

model CompetitionEntry {
  id            String    @id @default(cuid())
  competitionId String
  userId        String
  score         Int       @default(0)
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([competitionId, userId])
  @@index([competitionId])
  @@index([userId])
}

// ── Feed Reactions ────────────────────────────────────────────────────────────

model FeedReaction {
  id        String   @id @default(cuid())
  userId    String
  entryId   String
  entryType String
  reaction  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entryId, entryType, reaction])
  @@index([entryId, entryType])
  @@index([userId])
}

model FeedComment {
  id        String   @id @default(cuid())
  userId    String
  entryId   String
  entryType String
  body      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entryId, entryType])
  @@index([userId])
}

// ── Rate Limiting ─────────────────────────────────────────────────────────────

model RateLimitEvent {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

// ── Plan Pricing ──────────────────────────────────────────────────────────────

model PlanPricing {
  id        String   @id @default(cuid())
  role      String   @unique  // STUDENT | INSTRUCTOR | RECRUITER
  label     String
  priceAmt  Int      @default(0)  // cents per month; 0 = free
  updatedAt DateTime @updatedAt

  @@index([role])
}

// ── Vouchers ──────────────────────────────────────────────────────────────────

model Voucher {
  id          String    @id @default(cuid())
  code        String    @unique
  discountPct Int       @default(0)  // 0-100 percentage off
  discountAmt Int       @default(0)  // fixed discount in cents (applied after pct)
  maxUses     Int?                   // null = unlimited
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([code])
}

// ── Stripe Webhook Idempotency ────────────────────────────────────────────────

model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  processedAt   DateTime @default(now())
}

// ── Product Analytics ─────────────────────────────────────────────────────────

model AnalyticsEvent {
  id         String   @id @default(cuid())
  event      String
  userId     String?
  properties Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([event, createdAt])
  @@index([userId, createdAt])
}

// ── Modules & Structured Learning ────────────────────────────────────────────

enum ResourceType {
  PDF
  ARTICLE
  DOCUMENTATION
  GITHUB
  EXTERNAL_LINK
  TOOL_DOWNLOAD
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  MULTIPLE_SELECT
  SHORT_ANSWER
}

enum SubmissionType {
  TEXT
  PDF
  IMAGE
  ZIP
  GITHUB_LINK
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

model Module {
  id              String   @id @default(cuid())
  pathId          String
  title           String
  overview        String   @db.Text
  readingMaterial String   @db.Text
  order           Int
  isRequired      Boolean  @default(true)
  published       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  path       LearningPath       @relation(fields: [pathId], references: [id], onDelete: Cascade)
  resources  ModuleResource[]
  quiz       Quiz?
  assessment Assessment?
  progress   UserModuleProgress[]

  @@unique([pathId, order])
  @@index([pathId])
}

model ModuleResource {
  id       String       @id @default(cuid())
  moduleId String
  title    String
  type     ResourceType
  url      String
  order    Int          @default(0)

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
}

model Quiz {
  id          String   @id @default(cuid())
  moduleId    String   @unique
  title       String
  description String?
  passMark    Int      @default(70)
  createdAt   DateTime @default(now())

  module    Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id            String       @id @default(cuid())
  quizId        String
  type          QuestionType
  question      String       @db.Text
  options       Json?
  correctAnswer Json
  explanation   String?      @db.Text
  order         Int

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  quizId      String
  userId      String
  score       Int
  passed      Boolean
  completedAt DateTime @default(now())

  quiz    Quiz        @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId, userId])
  @@index([userId])
}

model QuizAnswer {
  id         String @id @default(cuid())
  attemptId  String
  questionId String
  answer     Json

  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
}

model Assessment {
  id           String   @id @default(cuid())
  moduleId     String   @unique
  title        String
  instructions String   @db.Text
  createdAt    DateTime @default(now())

  module      Module                 @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  submissions AssessmentSubmission[]
  rubric      AssessmentRubric?
}

model AssessmentSubmission {
  id           String         @id @default(cuid())
  assessmentId String
  userId       String
  type         SubmissionType
  content      String         @db.Text
  submittedAt  DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  assessment Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  review     MentorReview?
  portfolio  PortfolioItem?

  @@unique([assessmentId, userId])
  @@index([assessmentId])
  @@index([userId])
}

model MentorReview {
  id           String       @id @default(cuid())
  submissionId String       @unique
  reviewerId   String
  status       ReviewStatus
  grade        String?
  comment      String?      @db.Text
  reviewedAt   DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  submission   AssessmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer     User                 @relation("MentorReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  rubricScores RubricScore[]
}

model PortfolioItem {
  id           String   @id @default(cuid())
  userId       String
  submissionId String   @unique
  title        String
  description  String   @db.Text
  grade        String?
  feedback     String?  @db.Text
  isPublic     Boolean  @default(true)
  completedAt  DateTime @default(now())

  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  submission AssessmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserModuleProgress {
  id             String    @id @default(cuid())
  userId         String
  moduleId       String
  quizPassed     Boolean   @default(false)
  assessmentDone Boolean   @default(false)
  completedAt    DateTime?
  startedAt      DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
}

// ── Cohorts ───────────────────────────────────────────────────────────────────

model Cohort {
  id          String    @id @default(cuid())
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  joinCode    String    @unique
  published   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  // Optional: set when a cohort belongs to an Organization (e.g. auto-provisioned
  // via Nexus SSO). Null for standalone instructor-created cohorts.
  organizationId String?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  members      CohortMember[]
  paths        CohortPath[]

  @@index([organizationId])
}

model CohortMember {
  id       String   @id @default(cuid())
  cohortId String
  userId   String
  joinedAt DateTime @default(now())

  cohort Cohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cohortId, userId])
  @@index([cohortId])
  @@index([userId])
}

model CohortPath {
  id       String @id @default(cuid())
  cohortId String
  pathId   String

  cohort Cohort       @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  path   LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@unique([cohortId, pathId])
  @@index([cohortId])
}

// ── Assessment Rubrics ────────────────────────────────────────────────────────

model AssessmentRubric {
  id           String   @id @default(cuid())
  assessmentId String   @unique
  createdAt    DateTime @default(now())

  assessment Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  criteria   RubricCriterion[]
}

model RubricCriterion {
  id       String @id @default(cuid())
  rubricId String
  label    String
  maxScore Int    @default(10)
  order    Int    @default(0)

  rubric AssessmentRubric @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  scores RubricScore[]

  @@index([rubricId])
}

model RubricScore {
  id          String @id @default(cuid())
  criterionId String
  reviewId    String
  score       Int

  criterion RubricCriterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  review    MentorReview    @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([criterionId, reviewId])
  @@index([reviewId])
}

// ── Notifications ─────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // lab_assigned | sim_complete | badge_earned | writeup_approved | scenario_published | announcement
  title     String
  body      String?
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ── Writeups ──────────────────────────────────────────────────────────────────

enum WriteupStatus {
  PENDING
  APPROVED
  REJECTED
}

model Writeup {
  id        String        @id @default(cuid())
  userId    String
  labId     String
  title     String
  body      String        @db.Text
  status    WriteupStatus @default(PENDING)
  verdict   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab  Lab  @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@unique([userId, labId])
  @@index([labId, status])
  @@index([userId])
}
